<Window x:Class="Dev.Wpf.TestHost.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:controls="clr-namespace:Dev.Wpf.Controls;assembly=Dev.Wpf"
        xmlns:behaviors="clr-namespace:Dev.Wpf.Behaviors;assembly=Dev.Wpf"
        xmlns:vm="clr-namespace:Dev.Wpf.TestHost.ViewModels"
        mc:Ignorable="d"
        Title="Dev.Wpf TestHost"
        Width="960" Height="680"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <!-- ================================================================
             Toolbar
             ================================================================ -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar>

                <!-- Selection mode cycle -->
                <Label VerticalAlignment="Center" Margin="0,0,4,0">Selection:</Label>
                <Button Command="{Binding ToggleSelectionModeCommand}"
                        Content="{Binding SelectionModeLabel}"
                        ToolTip="Click to cycle: Single → Multiple → None → Single"
                        MinWidth="130"
                        Padding="8,3" />

                <Separator />

                <!-- Checkboxes toggle -->
                <ToggleButton IsChecked="{Binding ShowCheckboxes}"
                              ToolTip="Show or hide tri-state checkboxes on each node"
                              Padding="8,3">
                    Checkboxes
                </ToggleButton>

                <Separator />

                <!-- Drag-and-drop toggle -->
                <ToggleButton IsChecked="{Binding CanDragDrop}"
                              ToolTip="Enable or disable drag-and-drop reordering"
                              Padding="8,3">
                    Drag &amp; Drop
                </ToggleButton>

                <Separator />

                <!-- Theme placeholder -->
                <ToggleButton IsChecked="{Binding IsDarkTheme}"
                              ToolTip="Placeholder dark-theme toggle (Phase D: full ThemedIconProvider integration)"
                              Padding="8,3">
                    Dark Theme
                </ToggleButton>

            </ToolBar>
        </ToolBarTray>

        <!-- ================================================================
             Status bar
             ================================================================ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding SelectionModeLabel}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Checkboxes: off" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCheckboxes}" Value="True">
                                    <Setter Property="Text" Value="Checkboxes: on" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Drag &amp; Drop: off" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanDragDrop}" Value="True">
                                    <Setter Property="Text" Value="Drag &amp; Drop: on" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- ================================================================
             Main content area — light / dark placeholder theming applied here
             ================================================================ -->
        <Border Margin="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background"    Value="#FFFFFF" />
                    <Setter Property="BorderBrush"   Value="#CCCCCC" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Style.Triggers>
                        <!-- Placeholder dark theme — Phase D replaces this with a
                             full ResourceDictionary / ThemedIconProvider swap. -->
                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                            <Setter Property="Background"  Value="#1E1E1E" />
                            <Setter Property="BorderBrush" Value="#3C3C3C" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <controls:TreeViewControl
                x:Name="SampleTreeView"
                ItemsSource="{Binding RootNodes}"
                SelectionMode="{Binding SelectionMode}"
                ShowCheckboxes="{Binding ShowCheckboxes}"
                CanDragDrop="{Binding CanDragDrop}"
                ContextMenuProvider="{Binding ContextMenuProvider}">
                <i:Interaction.Behaviors>
                    <behaviors:SelectedNodesBindingBehavior
                        BoundSelectedNodes="{Binding SelectedNodes, Mode=OneWayToSource}" />
                    <behaviors:EventToCommandBehavior
                        EventName="NodesDropped"
                        Command="{Binding NodesDroppedCommand}" />
                </i:Interaction.Behaviors>
            </controls:TreeViewControl>
        </Border>

    </DockPanel>
</Window>
