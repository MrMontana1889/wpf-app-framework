<views:BaseWindow
    x:Class="Dev.Wpf.TestHost.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Dev.Wpf.Behaviors;assembly=Dev.Wpf"
    xmlns:controls="clr-namespace:Dev.Wpf.Controls;assembly=Dev.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Dev.Wpf.Views;assembly=Dev.Wpf"
    xmlns:vm="clr-namespace:Dev.Wpf.TestHost.ViewModels"
    Title="Dev.Wpf TestHost"
    Width="960"
    Height="680"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <!--<Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>-->

    <DockPanel LastChildFill="True">

        <!--
            ================================================================
            Menu bar (ThemeMode diagnostic)
            ================================================================
        -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Exit" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Dummy Item" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" />
            </MenuItem>
        </Menu>

        <!--
            ================================================================
            Toolbar
            ================================================================
        -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">

            <!--  =========================  -->
            <!--  Row 1: Existing controls  -->
            <!--  =========================  -->
            <ToolBar>

                <!--  Selection mode cycle  -->
                <Label Margin="0,0,4,0" VerticalAlignment="Center">
                    Selection:
                </Label>

                <Button
                    MinWidth="130"
                    Padding="8,3"
                    Command="{Binding ToggleSelectionModeCommand}"
                    Content="{Binding SelectionModeLabel}"
                    ToolTip="Click to cycle: Single → Multiple → None → Single" />

                <Separator />

                <!--  Checkboxes toggle  -->
                <ToggleButton
                    Padding="8,3"
                    IsChecked="{Binding ShowCheckboxes}"
                    ToolTip="Show or hide tri-state checkboxes on each node">
                    Checkboxes
                </ToggleButton>

                <Separator />

                <!--  Drag-and-drop toggle  -->
                <ToggleButton
                    Padding="8,3"
                    IsChecked="{Binding CanDragDrop}"
                    ToolTip="Enable or disable drag-and-drop reordering">
                    Drag &amp; Drop
                </ToggleButton>

                <Separator />

                <!--  Theme placeholder  -->
                <ToggleButton
                    Padding="8,3"
                    IsChecked="{Binding IsDarkTheme}"
                    ToolTip="Placeholder dark-theme toggle">
                    Dark Theme
                </ToggleButton>

            </ToolBar>

            <!--  =========================  -->
            <!--  Row 2: Diagnostic controls  -->
            <!--  =========================  -->
            <ToolBar Band="1">

                <!--  Checkbox  -->
                <CheckBox
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Content="Option A"
                    ToolTip="Test CheckBox in ToolBar" />

                <Separator />

                <!--  ComboBox  -->
                <ComboBox
                    Width="120"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    ToolTip="Test ComboBox in ToolBar">
                    <ComboBoxItem>Choice 1</ComboBoxItem>
                    <ComboBoxItem>Choice 2</ComboBoxItem>
                    <ComboBoxItem>Choice 3</ComboBoxItem>
                </ComboBox>

                <Separator />

                <!--  TextBox  -->
                <TextBox
                    Width="140"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="Filter text..."
                    ToolTip="Test TextBox in ToolBar" />

                <Separator />

                <!--  Radio buttons  -->
                <RadioButton
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Content="Mode A"
                    GroupName="ModeGroup" />

                <RadioButton
                    VerticalAlignment="Center"
                    Content="Mode B"
                    GroupName="ModeGroup" />

            </ToolBar>

        </ToolBarTray>

        <!--
            ================================================================
            Status bar
            ================================================================
        -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding SelectionModeLabel}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Checkboxes: off" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCheckboxes}" Value="True">
                                    <Setter Property="Text" Value="Checkboxes: on" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Drag &amp; Drop: off" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanDragDrop}" Value="True">
                                    <Setter Property="Text" Value="Drag &amp; Drop: on" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!--
            ================================================================
            Main content area — light / dark placeholder theming applied here
            ================================================================
        -->
        <Border Margin="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderThickness" Value="1" />
                </Style>
            </Border.Style>

            <controls:TreeViewControl
                x:Name="SampleTreeView"
                CanDragDrop="{Binding CanDragDrop}"
                ContextMenuProvider="{Binding ContextMenuProvider}"
                ItemsSource="{Binding RootNodes}"
                SelectionMode="{Binding SelectionMode}"
                ShowCheckboxes="{Binding ShowCheckboxes}">
                <i:Interaction.Behaviors>
                    <behaviors:SelectedNodesBindingBehavior BoundSelectedNodes="{Binding SelectedNodes, Mode=OneWayToSource}" />
                    <behaviors:EventToCommandBehavior Command="{Binding NodesDroppedCommand}" EventName="NodesDropped" />
                </i:Interaction.Behaviors>
            </controls:TreeViewControl>
        </Border>

    </DockPanel>
</views:BaseWindow>
