<views:BaseWindow
    x:Class="Dev.Wpf.TestHost.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Dev.Wpf.Behaviors;assembly=Dev.Wpf"
    xmlns:controls="clr-namespace:Dev.Wpf.Controls;assembly=Dev.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Dev.Wpf.Views;assembly=Dev.Wpf"
    xmlns:vm="clr-namespace:Dev.Wpf.TestHost.ViewModels"
    Title="Dev.Wpf TestHost"
    Width="960"
    Height="680"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <!--<Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>-->

    <DockPanel LastChildFill="True">

        <controls:MenuHostControl MenuBarId="{Binding MenuBarId}" DockPanel.Dock="Top" ItemsSource="{Binding MainMenuItems}" />
        <controls:ToolbarHostControl MenuBarId="{Binding MenuBarId}" ToolbarId="{Binding PrimaryToolbarId}" ToolbarRegistry="{Binding ToolbarRegistry}" DockPanel.Dock="Top" ItemsSource="{Binding PrimaryToolbarItems}" />
        <controls:ToolbarHostControl MenuBarId="{Binding MenuBarId}" ToolbarId="{Binding SecondaryToolbarId}" ToolbarRegistry="{Binding ToolbarRegistry}" DockPanel.Dock="Top" ItemsSource="{Binding SecondaryToolbarItems}" />

        <!--
            ================================================================
            Status bar
            ================================================================
        -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding SelectionModeLabel}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Checkboxes: off" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCheckboxes}" Value="True">
                                    <Setter Property="Text" Value="Checkboxes: on" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Drag &amp; Drop: off" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanDragDrop}" Value="True">
                                    <Setter Property="Text" Value="Drag &amp; Drop: on" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!--
            ================================================================
            Main content area — light / dark placeholder theming applied here
            ================================================================
        -->
        <Border Margin="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderThickness" Value="1" />
                </Style>
            </Border.Style>

            <controls:TreeViewControl
                x:Name="SampleTreeView"
                CanDragDrop="{Binding CanDragDrop}"
                ContextMenuProvider="{Binding ContextMenuProvider}"
                IconProvider="{Binding IconProvider}"
                ItemsSource="{Binding RootNodes}"
                SelectionMode="{Binding SelectionMode}"
                ShowCheckboxes="{Binding ShowCheckboxes}">
                <i:Interaction.Behaviors>
                    <behaviors:SelectedNodesBindingBehavior BoundSelectedNodes="{Binding SelectedNodes, Mode=OneWayToSource}" />
                    <behaviors:EventToCommandBehavior Command="{Binding NodesDroppedCommand}" EventName="NodesDropped" />
                </i:Interaction.Behaviors>
            </controls:TreeViewControl>
        </Border>

    </DockPanel>
</views:BaseWindow>
