<UserControl
    x:Class="Dev.Wpf.Views.PromptView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Dev.Wpf.Controls"
    xmlns:converters="clr-namespace:Dev.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Dev.Core.ViewModels;assembly=Dev.Core"
    d:DataContext="{d:DesignInstance vm:PromptViewModel}"
    Background="{DynamicResource WindowBackgroundBrush}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel Margin="24,20,24,20">

        <!--  Title  -->
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Text="{Binding TitleText}"
            TextWrapping="Wrap" />

        <!--  Message  -->
        <TextBlock
            Margin="0,12,0,0"
            Opacity="0.9"
            Text="{Binding MessageText}"
            TextWrapping="Wrap" />

        <!--  Separator  -->
        <Separator Margin="0,8,0,8" />

        <!--  Suppression Checkbox  -->
        <CheckBox
            Margin="0,12,0,0"
            Content="{Binding SuppressCheckboxText}"
            IsChecked="{Binding SuppressCheckboxChecked}"
            Visibility="{Binding ShowSuppressCheckbox, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!--  Button Panel  -->
        <StackPanel
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">

            <controls:WinFormsButton
                MinWidth="80"
                Margin="8,0,0,0"
                Command="{Binding YesCommand}"
                Content="Yes"
                IsDefault="True"
                Visibility="{Binding ShowYesButton, Converter={StaticResource BoolToVisibilityConverter}}" />

            <controls:WinFormsButton
                MinWidth="80"
                Margin="8,0,0,0"
                Command="{Binding NoCommand}"
                Content="No"
                Visibility="{Binding ShowNoButton, Converter={StaticResource BoolToVisibilityConverter}}" />

            <controls:WinFormsButton
                MinWidth="80"
                Margin="8,0,0,0"
                Command="{Binding OkCommand}"
                Content="OK"
                IsDefault="True"
                Visibility="{Binding ShowOkButton, Converter={StaticResource BoolToVisibilityConverter}}" />

            <controls:WinFormsButton
                MinWidth="80"
                Margin="8,0,0,0"
                Command="{Binding CancelCommand}"
                Content="Cancel"
                IsCancel="True"
                Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}}" />

        </StackPanel>

    </StackPanel>

</UserControl>
