<views:BaseDialog x:Class="Dev.Wpf.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Dev.Wpf.Views"
        xmlns:local="clr-namespace:Dev.Wpf.Views"
        xmlns:vm="clr-namespace:Dev.Core.ViewModels;assembly=Dev.Core"
        mc:Ignorable="d"
        Title="{Binding TitleText}"
        Width="450"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance vm:PromptViewModel}">

    <local:PromptView />

</views:BaseDialog>
