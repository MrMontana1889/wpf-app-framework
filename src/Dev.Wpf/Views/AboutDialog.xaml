<views:BaseDialog x:Class="Dev.Wpf.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Dev.Wpf.Views"
        xmlns:behaviors="clr-namespace:Dev.Wpf.Behaviors"
        xmlns:vm="clr-namespace:Dev.Core.ViewModels;assembly=Dev.Core"
        mc:Ignorable="d"
        Title="{Binding ApplicationLabel, StringFormat='About {0}'}"
        Width="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance vm:AboutDialogViewModel}"
        behaviors:DialogBehavior.DialogResult="{Binding DialogResult}">

    <StackPanel Margin="24,20,24,20">

        <TextBlock Text="{Binding ApplicationLabel}"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <TextBlock Text="{Binding Version}"
                   Margin="0,6,0,0"
                   Opacity="0.7" />

        <Separator Margin="0,16,0,16" />

        <Button Content="OK"
                HorizontalAlignment="Right"
                MinWidth="80"
                IsDefault="True"
                Command="{Binding CloseCommand}" />

    </StackPanel>

</views:BaseDialog>