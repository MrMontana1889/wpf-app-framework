<UserControl
    x:Class="Dev.Wpf.Controls.ToolbarControl"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="clr-namespace:Dev.Wpf.Controls"
    xmlns:converters="clr-namespace:Dev.Wpf.Converters"
    xmlns:vm="clr-namespace:Dev.Core.ViewModels.Controls;assembly=Dev.Core"
    mc:Ignorable="d"
    Background="Transparent"
    d:DataContext="{d:DesignInstance vm:ToolbarModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!--
            Self-contained compact MenuItem base for context-menu surfaces.
            All color values are resolved via DynamicResource so both light and
            dark themes are handled without any dependency on an external base style.
            This replaces the formerly implicit global MenuItem style that was
            removed in Phase 4.
        -->
        <Style x:Key="CompactMenuItemBaseStyle" BasedOn="{x:Null}" TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource MenuPopupBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource MenuPopupForeground}" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border
                                x:Name="OuterBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Path
                                        x:Name="CheckMark"
                                        Grid.Column="0"
                                        Width="9"
                                        Height="9"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 1,5 L 4,8 L 9,2"
                                        Stroke="{DynamicResource ControlForegroundBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.5"
                                        Visibility="Collapsed" />

                                    <ContentPresenter
                                        Grid.Column="1"
                                        ContentSource="Header"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        RecognizesAccessKey="True" />

                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="6,0,4,0"
                                        VerticalAlignment="Center"
                                        Foreground="{TemplateBinding Foreground}"
                                        Text="{TemplateBinding InputGestureText}" />
                                </Grid>
                            </Border>

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsSubmenuOpen}"
                                Placement="Right"
                                PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                                <Border
                                    Background="{DynamicResource MenuPopupBackground}"
                                    BorderBrush="{DynamicResource MenuPopupBorder}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource MenuPopupHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter Property="Background" Value="{DynamicResource MenuPopupHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuBarToggleMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource CompactMenuItemBaseStyle}">
            <Setter Property="Header" Value="Menu Bar" />
            <Setter Property="IsCheckable" Value="True" />
            <Setter Property="IsChecked" Value="{Binding IsChecked, Mode=OneWay}" />
            <Setter Property="Command" Value="{Binding ToggleCommand}" />
        </Style>
        <Style x:Key="ToolbarToggleMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource CompactMenuItemBaseStyle}">
            <Setter Property="Header" Value="{Binding Name}" />
            <Setter Property="IsCheckable" Value="True" />
            <Setter Property="IsChecked" Value="{Binding IsToolbarVisible, Mode=OneWay}" />
            <Setter Property="IsEnabled" Value="{Binding CanHide}" />
            <Setter Property="Command" Value="{Binding ToggleVisibilityCommand}" />
        </Style>
        <Style x:Key="ToolbarCustomizeMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource CompactMenuItemBaseStyle}">
            <Setter Property="Header" Value="Customize..." />
            <Setter Property="Command" Value="{Binding Command}" />
        </Style>
    </UserControl.Resources>

    <!--
        Context menu lives on the UserControl so right-clicking anywhere in the
        toolbar area (including directly on buttons) reliably shows the menu.
        Background="Transparent" ensures empty space between buttons is also
        hit-testable.
        The converter builds a flat list of: menu bar toggle entry,
        then all registered ToolbarModels, then (when CanCustomize=True)
        a Separator and a ToolbarCustomizeMenuEntry.
        The StyleSelector applies the correct MenuItem style per item type.
        Converter is declared inline to avoid resource-lookup scope issues inside ContextMenu.
        StyleSelector styles are in UserControl.Resources and referenced via StaticResource.
    -->
    <UserControl.ContextMenu>
        <ContextMenu Style="{DynamicResource ToolbarContextMenuStyle}">
            <ContextMenu.ItemsSource>
                <MultiBinding>
                    <MultiBinding.Converter>
                        <converters:ToolbarContextMenuConverter />
                    </MultiBinding.Converter>
                    <Binding
                        Path="PlacementTarget.MenuBarToggleEntry"
                        RelativeSource="{RelativeSource Self}" />
                    <Binding
                        Path="PlacementTarget.AllToolbars"
                        RelativeSource="{RelativeSource Self}" />
                    <Binding
                        Path="PlacementTarget.DataContext.CustomizeCommand"
                        RelativeSource="{RelativeSource Self}" />
                    <Binding
                        Path="PlacementTarget.CanCustomize"
                        RelativeSource="{RelativeSource Self}" />
                </MultiBinding>
            </ContextMenu.ItemsSource>
            <ContextMenu.ItemContainerStyleSelector>
                <controls:ToolbarMenuItemStyleSelector
                    MenuBarToggleStyle="{StaticResource MenuBarToggleMenuItemStyle}"
                    ToggleStyle="{StaticResource ToolbarToggleMenuItemStyle}"
                    CustomizeStyle="{StaticResource ToolbarCustomizeMenuItemStyle}" />
            </ContextMenu.ItemContainerStyleSelector>
        </ContextMenu>
    </UserControl.ContextMenu>

    <ItemsControl ItemsSource="{Binding Items}">

        <ItemsControl.Resources>
            <DataTemplate DataType="{x:Type vm:ToolbarItemModel}">
                <controls:WinFormsButton
                    Margin="2"
                    Padding="10,4"
                    Command="{Binding Command}"
                    Content="{Binding Label}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ToolbarSelectionItemModel}">
                <StackPanel
                    Margin="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        Text="{Binding Label}"
                        Visibility="{Binding ShowLabel, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ComboBox
                        MinWidth="130"
                        VerticalAlignment="Center"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding Options}"
                        SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Value" />
                </StackPanel>
            </DataTemplate>
        </ItemsControl.Resources>

        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Margin="4,2" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

    </ItemsControl>

</UserControl>