<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Dev.Wpf.Controls"
    xmlns:converters="clr-namespace:Dev.Wpf.Converters"
    xmlns:behaviors="clr-namespace:Dev.Wpf.Behaviors"
    xmlns:toolbarCore="clr-namespace:Dev.Core.Toolbar;assembly=Dev.Core">

    <Style TargetType="StatusBar">
        <Setter Property="Background"
            Value="{DynamicResource Toolbar.Background}" />

        <Setter Property="BorderBrush"
            Value="{DynamicResource Toolbar.Border}" />

        <Setter Property="BorderThickness" Value="1,1,1,0" />

        <Setter Property="Foreground"
            Value="{DynamicResource ToolbarItem.Foreground}" />

        <Setter Property="Padding" Value="6,2"/>
    </Style>

    
    <!--  Default (design-time) style for WinFormsButton.  -->
    <!--  At runtime this is superseded by WinFormsButtonStyle.{theme}.xaml loaded by ThemeManager.  -->
    <Style TargetType="{x:Type controls:WinFormsButton}">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Height" Value="27" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Background" Value="{DynamicResource ToolbarButton.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarButton.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButton.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:WinFormsButton}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ToolbarItem.Background.Hover}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButton.MouseOver.Border}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ToolbarButton.Pressed.Background}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButton.Pressed.Border}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}" />
                            <Setter Property="Background" Value="{DynamicResource ToolbarButton.Disabled.Background}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButton.Disabled.Border}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════════
        OverlayHostControl — Phase O2 visual modality layer
        ═══════════════════════════════════════════════════════════════════
        Projects the top overlay from IModeService.ActiveOverlays, adds a
        full-surface interaction-blocking background layer, and renders
        overlay content via standard WPF DataTemplate resolution.
    -->
    <Style TargetType="{x:Type controls:OverlayHostControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:OverlayHostControl}">
                    <Grid Background="Transparent">
                        <Border
                            x:Name="PART_BlockingLayer"
                            Background="{DynamicResource OverlayBackgroundBrush}"
                            IsHitTestVisible="True"
                            Visibility="Visible" />

                        <ContentPresenter
                            x:Name="PART_OverlayPresenter"
                            Content="{Binding ActiveOverlay, RelativeSource={RelativeSource TemplatedParent}}"
                            IsHitTestVisible="True"
                            Visibility="Visible" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="ActiveOverlay" Value="{x:Null}">
                            <Setter TargetName="PART_BlockingLayer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_BlockingLayer" Property="IsHitTestVisible" Value="False" />
                            <Setter TargetName="PART_OverlayPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_OverlayPresenter" Property="IsHitTestVisible" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════════
        MenuHostControl — Phase M2 (Core MenuItem projection)
        ═══════════════════════════════════════════════════════════════════
        Projects Dev.Core semantic menu items into a native WPF Menu surface.
        Consumers bind ItemsSource and rely on built-in projection behavior.
    -->
    <Style TargetType="{x:Type controls:MenuHostControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MenuHostControl}">

                    <Menu
                          Background="{TemplateBinding Background}"
                          Foreground="{TemplateBinding Foreground}"
                          ItemsSource="{Binding ProjectedItems, RelativeSource={RelativeSource TemplatedParent}}">

                        <Menu.Resources>

                            <!-- ✅ Fully owned MenuItem styling -->
                            <Style TargetType="MenuItem">

                                <!-- Match toolbar density -->
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Margin" Value="4,0,4,4"/>

                                <!-- Theme -->
                                <Setter Property="Background" Value="{DynamicResource Toolbar.Background}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ToolbarItem.Foreground}"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">

                                            <Grid>

                                                <!-- ===== Root Layout ===== -->
                                                <Border x:Name="Root" Background="{TemplateBinding Background}">

                                                    <Grid Margin="{TemplateBinding Padding}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition x:Name="IconColumn" Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Icon -->
                                                        <ContentPresenter
                                                            x:Name="IconPresenter"
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            ContentSource="Icon"/>

                                                        <!-- Header -->
                                                        <ContentPresenter
                                                            Grid.Column="1"
                                                            Margin="4,0"
                                                            VerticalAlignment="Center"
                                                            RecognizesAccessKey="True"
                                                            ContentSource="Header"/>

                                                        <!-- Shortcut text -->
                                                        <TextBlock
                                                            x:Name="Shortcut"
                                                            Grid.Column="2"
                                                            Margin="8,0,4,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="{TemplateBinding Foreground}"
                                                            Text="{TemplateBinding InputGestureText}"/>

                                                    </Grid>

                                                </Border>

                                                <!-- ===== Submenu Popup ===== -->
                                                <Popup x:Name="PART_Popup"
                                                     Placement="Bottom"
                                                     AllowsTransparency="True"
                                                     IsOpen="{TemplateBinding IsSubmenuOpen}">

                                                    <Border
                                                      Background="{DynamicResource Toolbar.Background}"
                                                      BorderBrush="{DynamicResource Toolbar.Border}"
                                                      BorderThickness="1">

                                                        <StackPanel IsItemsHost="True"/>

                                                    </Border>

                                                </Popup>

                                            </Grid>

                                            <!-- ===== Behavior ===== -->
                                            <ControlTemplate.Triggers>

                                                <!-- Hover -->
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource ToolbarItem.Background.Hover}"/>
                                                </Trigger>

                                                <!-- Disabled -->
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </Trigger>

                                                <Trigger Property="Role" Value="TopLevelHeader">
                                                    <!-- Kill all left padding / icon layout -->
                                                    <Setter TargetName="IconColumn" Property="Width" Value="0"/>
                                                    <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>

                                                    <!-- Tighten spacing to match WinForms-style menus -->
                                                    <Setter Property="Padding" Value="2"/>

                                                    <Setter TargetName="Shortcut" Property="Width" Value="0" />
                                                    <Setter TargetName="Shortcut" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                                
                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>

                            </Style>

                        </Menu.Resources>

                    </Menu>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!--
        ═══════════════════════════════════════════════════════════════════
        ToolbarHostControl — Phase 2 (Core ToolbarItem projection)
        ═══════════════════════════════════════════════════════════════════
        Projects Dev.Core toolbar item data into native WPF controls using
        built-in DataTemplates. Consumers bind ItemsSource to ToolbarItem data
        and do not need to author custom templates for baseline usage.
    -->
    <Style TargetType="{x:Type controls:ToolbarHostControl}">
        <Style.Resources>

            <Style x:Key="ToolbarIconStyle" TargetType="Image">
                <Setter Property="Margin" Value="2,0,0,0" />
                <Setter Property="Width" Value="16"/>
                <Setter Property="Height" Value="16"/>
                <Setter Property="Stretch" Value="Uniform"/>
            </Style>

            <Style x:Key="ToolbarCompactCheckBoxStyle"
                   TargetType="CheckBox">

                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Margin" Value="4,0,4,0" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border Background="Transparent" Padding="2">
                                <BulletDecorator VerticalAlignment="Center">
                                    <BulletDecorator.Bullet>
                                        <Border x:Name="CheckBoxBorder"
                                            Width="14"
                                            Height="14"
                                            Background="{DynamicResource Checkbox.Background}"
                                            BorderBrush="{DynamicResource Checkbox.Border}"
                                            BorderThickness="1">
                                            <Grid IsHitTestVisible="False">
                                                <Path x:Name="CheckMark"
                                                      Width="10"
                                                      Height="10"
                                                      Data="M 1,5 L 4,8 L 9,2"
                                                      Stroke="{DynamicResource Checkbox.Glyph}"
                                                      StrokeThickness="2"
                                                      Visibility="Collapsed"/>
                                                <Rectangle x:Name="IndeterminateMark"
                                               Width="8"
                                               Height="2"
                                               Fill="{DynamicResource Checkbox.Glyph}"
                                               Visibility="Collapsed"/>
                                            </Grid>
                                        </Border>
                                    </BulletDecorator.Bullet>
                                    <ContentPresenter
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </BulletDecorator>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="{x:Null}">
                                    <Setter TargetName="IndeterminateMark" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ToolbarItem.Foreground}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Margin" Value="4,0,4,0" />
                <Setter Property="Padding" Value="8" />

                <Style.Triggers>

                    <!-- Disabled (inherits from parent button) -->
                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                        <Setter Property="Opacity" Value="0.6"/>
                    </DataTrigger>

                </Style.Triggers>
            </Style>

            <Style x:Key="ToolbarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ToolbarItem.Background.Normal}" />
                <Setter Property="Foreground" Value="{DynamicResource ToolbarItem.Foreground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Toolbar.Border}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Margin" Value="4,0,4,0" />
                <Setter Property="Padding" Value="4" />

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">

                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>

                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Hover}" />
                                </Trigger>

                                <!-- Pressed -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Pressed}" />
                                </Trigger>

                                <!-- Disabled -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="{DynamicResource ToolbarItem.Background.Normal}" />
                <Setter Property="Foreground" Value="{DynamicResource ToolbarItem.Foreground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Toolbar.Border}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Margin" Value="4,0,4,0" />
                <Setter Property="Padding" Value="4" />

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">

                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>

                                <!-- Checked -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Checked}" />
                                    <Setter Property="Foreground"
                                        Value="{DynamicResource ToolbarItem.Foreground.Checked}" />
                                </Trigger>

                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Hover}" />
                                </Trigger>

                                <!-- Pressed -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Pressed}" />
                                </Trigger>

                                <!-- Disabled -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">

                <Setter Property="Background" Value="{DynamicResource ToolbarItem.Background.Normal}" />
                <Setter Property="Foreground" Value="{DynamicResource ToolbarItem.Foreground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Toolbar.Border}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource ToolbarItem.Foreground}" />
                <Setter Property="TextElement.Background" Value="{DynamicResource Toolbar.Background}" />
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Margin" Value="4,0,4,0" />
                <Setter Property="Padding" Value="4" />

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">

                            <Grid>

                                <ToggleButton x:Name="MainToggle"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">


                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border
                                                x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">

                                                <ContentPresenter/>
                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <!-- ✅ Hover -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root"
                                                        Property="Background"
                                                        Value="{DynamicResource ToolbarItem.Background.Hover}" />
                                                </Trigger>

                                                <!-- ✅ Open / Checked -->
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Root"
                                                        Property="Background"
                                                        Value="{DynamicResource ToolbarItem.Background.Pressed}" />
                                                </Trigger>

                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>

                                    <DockPanel>


                                        <ContentPresenter
                                            Margin="4,0,20,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            RecognizesAccessKey="True">

                                            <!-- ✅ THIS is the fix -->
                                            <ContentPresenter.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource ToolbarItem.Foreground}" />
                                                </Style>
                                            </ContentPresenter.Resources>

                                        </ContentPresenter>

                                        <Path
                                            DockPanel.Dock="Right"
                                            Margin="4"
                                            Width="8"
                                            Height="4"
                                            Data="M 0 0 L 4 4 L 8 0 Z"
                                            Fill="{TemplateBinding Foreground}"
                                            VerticalAlignment="Center"/>

                                    </DockPanel>

                                </ToggleButton>
                                
                                <Popup
                                    Name="PART_Popup"
                                    Placement="Bottom"
                                    IsOpen="{TemplateBinding IsDropDownOpen}"
                                    AllowsTransparency="True">

                                    <Border
                                        Background="{DynamicResource Toolbar.Background}"
                                        BorderBrush="{DynamicResource Toolbar.Border}"
                                        BorderThickness="1">

                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>

                                    </Border>

                                </Popup>

                            </Grid>


                            <ControlTemplate.Triggers>


                                <Trigger SourceName="MainToggle" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MainToggle"
                                        Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Hover}" />
                                </Trigger>

                                <!-- ✅ Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MainToggle"
                                        Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Hover}" />
                                </Trigger>

                                <!-- ✅ Pressed / Open -->
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="MainToggle"
                                        Property="Background"
                                        Value="{DynamicResource ToolbarItem.Background.Pressed}" />
                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
        </Style.Resources>
        
        <Setter Property="Background" Value="{DynamicResource Toolbar.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Toolbar.Border}" />
        <Setter Property="Margin" Value="4,0,4,4" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToolbarHostControl}">
                    <ControlTemplate.Resources>
                        <converters:BoolToVisibilityConverter x:Key="ToolbarBoolToVisibilityConverter" />
                        <converters:ToolbarDisplayIntentToVisibilityConverter x:Key="ToolbarDisplayIntentToVisibilityConverter" />
                        <converters:ToolbarItemLabelConverter x:Key="ToolbarItemLabelConverter" />
                        <converters:IconKeyToImageSourceConverter x:Key="ToolbarIconKeyToImageSourceConverter" />

                        <DataTemplate x:Key="ToolbarButtonTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <Button
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding Command}"
                                IsEnabled="{Binding IsEnabled}"
                                ToolTip="{Binding SemanticMetadata.Text.AssistiveText}"
                                Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Style="{StaticResource ToolbarIconStyle}" Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Icon}">
                                        <Image.Source>
                                            <MultiBinding Converter="{StaticResource ToolbarIconKeyToImageSourceConverter}">
                                                <Binding Path="SemanticMetadata.IconKey" />
                                                <Binding Path="IconProvider" RelativeSource="{RelativeSource AncestorType=controls:ToolbarHostControl}" />
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                    <TextBlock
                                        Margin="4,0,4,0"
                                        Text="{Binding Converter={StaticResource ToolbarItemLabelConverter}}"
                                        Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Text}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>

                        <DataTemplate x:Key="ToolbarDropDownTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <Menu
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                IsEnabled="{Binding IsEnabled}"
                                Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}">
                                <Menu.Resources>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding SemanticMetadata.Text.Label}" />
                                        <Setter Property="Command" Value="{Binding Command}" />
                                        <Setter Property="ItemsSource" Value="{Binding Children}" />
                                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                        <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}" />
                                    </Style>
                                </Menu.Resources>

                                <MenuItem
                                    Header="{Binding SemanticMetadata.Text.Label}"
                                    Command="{x:Null}"
                                    ItemsSource="{Binding Children}"
                                    ToolTip="{Binding SemanticMetadata.Text.AssistiveText}" />
                            </Menu>
                        </DataTemplate>

                        <DataTemplate x:Key="ToolbarSplitDropDownTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <Grid
                                IsEnabled="{Binding IsEnabled}"
                                Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="0"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding Command}"
                                    IsEnabled="{Binding IsEnabled}"
                                    ToolTip="{Binding SemanticMetadata.Text.AssistiveText}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Style="{StaticResource ToolbarIconStyle}" Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Icon}">
                                            <Image.Source>
                                                <MultiBinding Converter="{StaticResource ToolbarIconKeyToImageSourceConverter}">
                                                    <Binding Path="SemanticMetadata.IconKey" />
                                                    <Binding Path="IconProvider" RelativeSource="{RelativeSource AncestorType=controls:ToolbarHostControl}" />
                                                </MultiBinding>
                                            </Image.Source>
                                        </Image>
                                        <TextBlock
                                            Margin="4,0,4,0"
                                            Text="{Binding Converter={StaticResource ToolbarItemLabelConverter}}"
                                            Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Text}" />
                                    </StackPanel>
                                </Button>

                                <Menu
                                    Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Focusable="False"
                                    IsEnabled="{Binding IsEnabled}">
                                    <Menu.Resources>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding SemanticMetadata.Text.Label}" />
                                            <Setter Property="Command" Value="{Binding Command}" />
                                            <Setter Property="ItemsSource" Value="{Binding Children}" />
                                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}" />
                                        </Style>
                                    </Menu.Resources>

                                    <MenuItem
                                        Header="▼"
                                        Command="{x:Null}"
                                        ItemsSource="{Binding Children}"
                                        ToolTip="{Binding SemanticMetadata.Text.AssistiveText}" />
                                </Menu>
                            </Grid>
                        </DataTemplate>

                        <DataTemplate x:Key="ToolbarToggleButtonTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <ToggleButton
                                Style="{StaticResource ToolbarToggleButtonStyle}"
                                Command="{Binding Command}"
                                IsChecked="{Binding IsChecked, Mode=OneWay}"
                                IsEnabled="{Binding IsEnabled}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                ToolTip="{Binding SemanticMetadata.Text.AssistiveText}"
                                Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Style="{StaticResource ToolbarIconStyle}" Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Icon}">
                                        <Image.Source>
                                            <MultiBinding Converter="{StaticResource ToolbarIconKeyToImageSourceConverter}">
                                                <Binding Path="SemanticMetadata.IconKey" />
                                                <Binding Path="IconProvider" RelativeSource="{RelativeSource AncestorType=controls:ToolbarHostControl}" />
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                    <TextBlock
                                        Margin="4,0,4,0"
                                        Text="{Binding SemanticMetadata.Text.Label}"
                                        Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Text}" />
                                </StackPanel>
                            </ToggleButton>
                        </DataTemplate>

                        <DataTemplate x:Key="ToolbarCheckBoxTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <CheckBox
                                Style="{StaticResource ToolbarCompactCheckBoxStyle}"
                                Command="{Binding Command}"
                                VerticalAlignment="Center"
                                IsChecked="{Binding IsChecked, Mode=OneWay}"
                                IsEnabled="{Binding IsEnabled}"
                                ToolTip="{Binding SemanticMetadata.Text.AssistiveText}"
                                Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Style="{StaticResource ToolbarIconStyle}" Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Icon}">
                                        <Image.Source>
                                            <MultiBinding Converter="{StaticResource ToolbarIconKeyToImageSourceConverter}">
                                                <Binding Path="SemanticMetadata.IconKey" />
                                                <Binding Path="IconProvider" RelativeSource="{RelativeSource AncestorType=controls:ToolbarHostControl}" />
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                    <TextBlock
                                        Margin="4,0,4,0"
                                        Text="{Binding SemanticMetadata.Text.Label}"
                                        Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Text}" />
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>

                        <DataTemplate x:Key="ToolbarLabelTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <StackPanel
                                IsEnabled="{Binding IsEnabled}"
                                Orientation="Horizontal"
                                ToolTip="{Binding SemanticMetadata.Text.AssistiveText}"
                                Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}">
                                <Image Style="{StaticResource ToolbarIconStyle}" Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Icon}">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource ToolbarIconKeyToImageSourceConverter}">
                                            <Binding Path="SemanticMetadata.IconKey" />
                                            <Binding Path="IconProvider" RelativeSource="{RelativeSource AncestorType=controls:ToolbarHostControl}" />
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Style="{StaticResource ToolbarLabelStyle}"
                                    VerticalAlignment="Center"
                                    Text="{Binding SemanticMetadata.Text.Label}"
                                    Visibility="{Binding DisplayIntent, Converter={StaticResource ToolbarDisplayIntentToVisibilityConverter}, ConverterParameter=Text}" />
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate x:Key="ToolbarComboBoxTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <ComboBox
                                Style="{StaticResource ToolbarComboBoxStyle}"
                                IsEnabled="{Binding IsEnabled}"
                                ItemsSource="{Binding SelectionItems}"
                                SelectedItem="{Binding SelectedValue, Mode=OneWay}"
                                ToolTip="{Binding SemanticMetadata.Text.AssistiveText}"
                                behaviors:ComboBoxSelection.EnableSelectionForwarding="True"
                                Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}" />
                        </DataTemplate>

                        <DataTemplate x:Key="ToolbarSeparatorTemplate" DataType="{x:Type toolbarCore:ToolbarItem}">
                            <Separator Visibility="{Binding IsVisible, Converter={StaticResource ToolbarBoolToVisibilityConverter}}" />
                        </DataTemplate>

                        <controls:ToolbarItemTemplateSelector
                            x:Key="ToolbarItemTemplateSelector"
                            ButtonTemplate="{StaticResource ToolbarButtonTemplate}"
                            CheckBoxTemplate="{StaticResource ToolbarCheckBoxTemplate}"
                            ComboBoxTemplate="{StaticResource ToolbarComboBoxTemplate}"
                            DropDownTemplate="{StaticResource ToolbarDropDownTemplate}"
                            LabelTemplate="{StaticResource ToolbarLabelTemplate}"
                            SeparatorTemplate="{StaticResource ToolbarSeparatorTemplate}"
                            SplitDropDownTemplate="{StaticResource ToolbarSplitDropDownTemplate}"
                            ToggleButtonTemplate="{StaticResource ToolbarToggleButtonTemplate}" />
                    </ControlTemplate.Resources>

                    <Border Background="{TemplateBinding Background}" ClipToBounds="True">
                        <ItemsControl
                            x:Name="PART_ItemsHost"
                            Foreground="{TemplateBinding Foreground}"
                            ItemTemplateSelector="{StaticResource ToolbarItemTemplateSelector}"
                            ItemsSource="{Binding ProjectedItems, RelativeSource={RelativeSource TemplatedParent}}">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <Border ClipToBounds="True">
                                        <ItemsPresenter />
                                    </Border>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════════
        TreeViewControl — Phase C baseline
        ═══════════════════════════════════════════════════════════════════
        Uses a ScrollViewer › ItemsPresenter layout. The ItemsPanel is
        overridden to VirtualizingStackPanel (recycling mode) so the root
        level virtualizes large flat item sets. Nested child levels use the
        non-virtualizing StackPanel inside TreeChildItemsControl.
    -->
    <Style TargetType="{x:Type controls:TreeViewControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <!--
                        VirtualizingPanel.IsVirtualizing and
                        VirtualizationMode=Recycling are set globally in
                        TreeViewControl's static constructor so they apply
                        regardless of which ItemsPanel template is in use.
                        They are also set here explicitly on the panel element
                        so the VirtualizingStackPanel itself reads the correct
                        values when queried via GetVirtualizationMode(panel).
                    -->
                    <VirtualizingStackPanel
                        IsItemsHost="True"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TreeViewControl}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <!--
                            CanContentScroll="False" enables pixel-based scrolling,
                            which is required for nested tree structures where child
                            levels are not direct children of the VirtualizingStackPanel.
                            Padding reserves space so content never slides behind the
                            Fluent overlay scrollbars introduced by ThemeMode="System".
                        -->
                        <ScrollViewer
                            Padding="0,8,0,8"
                            CanContentScroll="False"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ═══════════════════════════════════════════════════════════════════
        TreeNodeContainer — keyed by TreeViewControl.NodeContainerStyleKey
        ═══════════════════════════════════════════════════════════════════
        TreeNodeContainer.DefaultStyleKey is overridden to this
        ComponentResourceKey so WPF resolves this style automatically for
        every container instance without requiring an explicit
        ItemContainerStyle assignment.
        
        Layout — each node row is a Grid with four columns:
        [0] PART_ExpandCollapseGlyph  ToggleButton  16 px wide
        [1] PART_CheckBox             CheckBox      hidden by default
        [2] PART_IconPresenter        ContentPresenter  16 px wide
        [3] PART_LabelPresenter       TextBlock     fills remaining width
        
        Below the row, PART_ChildrenPresenter (TreeChildItemsControl) is
        indented by one fixed step (16 px) and hidden when IsExpanded=False.
        
        Visual States:
        Selection — highlights the node row background and foreground
        Hover — subtle background change on mouse-over
        Focus — visible border around the node row
        Disabled — dimmed text and glyph appearance
        
        Triggers:
        IsExpanded = True   → PART_ChildrenPresenter becomes Visible
        IsExpandable = False → PART_ExpandCollapseGlyph becomes Hidden
    -->
    <Style x:Key="{x:Static controls:TreeViewControl.NodeContainerStyleKey}" TargetType="{x:Type controls:TreeNodeContainer}">
        <Setter Property="Background" Value="{DynamicResource TreeNode.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource TreeNode.Foreground}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TreeNodeContainer}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  ── Node row with interactive states ───────  -->
                        <Border
                            x:Name="PART_NodeRowBorder"
                            Grid.Row="0"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">

                            <Grid Margin="2,1">
                                <Grid.ColumnDefinitions>
                                    <!--  0 · expand/collapse glyph  -->
                                    <ColumnDefinition Width="16" />
                                    <!--  1 · checkbox (hidden until ShowCheckboxes is Phase D)  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  2 · icon placeholder  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  3 · label  -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--
                                    PART_ExpandCollapseGlyph
                                    IsChecked two-way bound to TreeNodeModel.IsExpanded.
                                    When toggled, ToggleButton.CheckedEvent /
                                    UncheckedEvent bubbles to TreeViewControl where
                                    ExpandCollapseBehavior handles it.
                                -->
                                <ToggleButton
                                    x:Name="PART_ExpandCollapseGlyph"
                                    Grid.Column="0"
                                    Width="16"
                                    Height="16"
                                    MinWidth="0"
                                    MinHeight="0"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Focusable="False"
                                    IsChecked="{Binding IsExpanded, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                                <TextBlock
                                                    x:Name="GlyphText"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource TreeNode.Glyph.Foreground}"
                                                    Text="&#xE76C;" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="GlyphText" Property="Text" Value="&#xE70D;" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="GlyphText" Property="Foreground" Value="{DynamicResource TreeNode.Glyph.Hover}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=controls:TreeNodeContainer}}" Value="False">
                                                    <Setter TargetName="GlyphText" Property="Foreground" Value="{DynamicResource TreeNode.Disabled.Foreground}" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!--
                                    PART_CheckBox
                                    Collapsed by default; enabled per node when
                                    TreeViewControl.ShowCheckboxes = True (Phase D).
                                    IsChecked two-way bound with IsThreeState=True
                                    so CheckBox.CheckedEvent / UncheckedEvent /
                                    IndeterminateEvent bubble to CheckboxBehavior.
                                -->
                                <CheckBox
                                    x:Name="PART_CheckBox"
                                    Grid.Column="1"
                                    Width="16"
                                    Height="16"
                                    MinWidth="0"
                                    MinHeight="0"
                                    Margin="0"
                                    Padding="2,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                    IsThreeState="True"
                                    Visibility="Collapsed">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border
                                                x:Name="CheckBoxBorder"
                                                Width="14"
                                                Height="14"
                                                Background="{DynamicResource Checkbox.Background}"
                                                BorderBrush="{DynamicResource Checkbox.Border}"
                                                BorderThickness="1"
                                                SnapsToDevicePixels="True">
                                                <Grid>
                                                    <!--  Check mark glyph  -->
                                                    <Path
                                                        x:Name="CheckMark"
                                                        Width="10"
                                                        Height="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Data="M 1,5 L 4,8 L 9,2"
                                                        Stroke="{DynamicResource Checkbox.Glyph}"
                                                        StrokeEndLineCap="Round"
                                                        StrokeLineJoin="Round"
                                                        StrokeStartLineCap="Round"
                                                        StrokeThickness="2"
                                                        Visibility="Collapsed" />
                                                    <!--  Indeterminate glyph  -->
                                                    <Rectangle
                                                        x:Name="IndeterminateMark"
                                                        Width="8"
                                                        Height="2"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Fill="{DynamicResource Checkbox.Glyph}"
                                                        Visibility="Collapsed" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!--  Checked state  -->
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource Checkbox.Checked.Background}" />
                                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Checkbox.Checked.Border}" />
                                                </Trigger>
                                                <!--  Indeterminate state  -->
                                                <Trigger Property="IsChecked" Value="{x:Null}">
                                                    <Setter TargetName="IndeterminateMark" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource Checkbox.Checked.Background}" />
                                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Checkbox.Checked.Border}" />
                                                </Trigger>
                                                <!--  Hover state  -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource Checkbox.Hover.Background}" />
                                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Checkbox.Hover.Border}" />
                                                </Trigger>
                                                <!--  Disabled state  -->
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource Checkbox.Disabled.Background}" />
                                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Checkbox.Disabled.Border}" />
                                                    <Setter TargetName="CheckMark" Property="Stroke" Value="{DynamicResource Checkbox.Disabled.Glyph}" />
                                                    <Setter TargetName="IndeterminateMark" Property="Fill" Value="{DynamicResource Checkbox.Disabled.Glyph}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>

                                <!--
                                    PART_IconPresenter
                                    Placeholder — icon content is supplied in
                                    Phase D via IIconProvider / IconConverter.
                                -->
                                <ContentPresenter
                                    x:Name="PART_IconPresenter"
                                    Grid.Column="2"
                                    Width="16"
                                    Height="16"
                                    Margin="2,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center" />

                                <!--
                                    PART_LabelPresenter
                                    Displays TreeNodeModel.Label. Search
                                    highlighting (IsMatch) is wired in Phase D.
                                -->
                                <TextBlock
                                    x:Name="PART_LabelPresenter"
                                    Grid.Column="3"
                                    Margin="2,0"
                                    VerticalAlignment="Center"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{Binding Label}" />
                            </Grid>
                        </Border>

                        <!--  ── Children ───────────────────────────────  -->
                        <!--
                            PART_ChildrenPresenter
                            Collapsed until IsExpanded=True (see trigger below).
                            Fixed 16 px left indent creates one level of visual
                            depth per nesting; final indentation sizing is Phase D.
                            ItemsSource binds to TreeNodeModel.Children
                            (ObservableCollection<TreeNodeModel>).
                        -->
                        <controls:TreeChildItemsControl
                            x:Name="PART_ChildrenPresenter"
                            Grid.Row="1"
                            Margin="16,0,0,0"
                            ItemsSource="{Binding Children}"
                            Visibility="Collapsed" />

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!--  Show checkboxes when TreeViewControl.ShowCheckboxes is true and node is checkable  -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ShowCheckboxes, RelativeSource={RelativeSource AncestorType=controls:TreeViewControl}}" Value="True" />
                                <Condition Binding="{Binding IsCheckable}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter TargetName="PART_CheckBox" Property="Visibility" Value="Visible" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>

                        <!--  Show children when the node is expanded  -->
                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                            <Setter TargetName="PART_ChildrenPresenter" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <!--  Hide the glyph for non-expandable leaf nodes  -->
                        <DataTrigger Binding="{Binding IsExpandable}" Value="False">
                            <Setter TargetName="PART_ExpandCollapseGlyph" Property="Visibility" Value="Hidden" />
                        </DataTrigger>

                        <!--  Selection state  -->
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="PART_NodeRowBorder" Property="Background" Value="{DynamicResource TreeNode.Selected.Background}" />
                            <Setter Property="Foreground" Value="{DynamicResource TreeNode.Selected.Foreground}" />
                        </DataTrigger>

                        <!--  Hover state (only when not selected)  -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                <Condition Binding="{Binding IsSelected}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter TargetName="PART_NodeRowBorder" Property="Background" Value="{DynamicResource TreeNode.Hover.Background}" />
                                <Setter Property="Foreground" Value="{DynamicResource TreeNode.Hover.Foreground}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>

                        <!--  Focus state  -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PART_NodeRowBorder" Property="BorderBrush" Value="{DynamicResource TreeNode.Focus.Border}" />
                        </Trigger>

                        <!--  Disabled state  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TreeNode.Disabled.Foreground}" />
                        </Trigger>

                        <!--  Visibility shaping (E8f): collapse nodes filtered out by view model  -->
                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
