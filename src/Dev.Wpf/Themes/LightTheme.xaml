<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Brushes  -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextBrush" Color="#000000" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#CCCCCC" />

    <!--  Light blue-ish  -->
    <SolidColorBrush x:Key="SelectedItemBackgroundBrush" Color="#CDE6F7" />
    <SolidColorBrush x:Key="SelectedItemForegroundBrush" Color="Black" />
    <SolidColorBrush x:Key="TreeExpanderVisibleBrush" Color="Black" />
    <SolidColorBrush x:Key="TreeExpanderHiddenBrush" Color="Transparent" />

    <SolidColorBrush x:Key="SearchTextBoxBackgroundBrush" Color="White" />
    <SolidColorBrush x:Key="SearchTextBoxForegroundBrush" Color="Black" />
    <SolidColorBrush x:Key="SearchTextBoxCaretBrush" Color="Black" />
    <SolidColorBrush x:Key="SearchTextBoxWatermarkBrush" Color="#888888" />

    <!--  Light  -->
    <SolidColorBrush x:Key="PropertyGridEditorBackgroundBrush" Color="White" />

    <SolidColorBrush x:Key="TextBrushOnLightBackground" Color="Black" />

    <!--  Light blue with better contrast  -->
    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="#FF3399FF" />
    <SolidColorBrush x:Key="SelectedTextBrush" Color="Black" />

    <SolidColorBrush x:Key="SelectedTabBackgroundBrush" Color="#FFD6EAF8" />
    <!--  Light blue  -->
    <SolidColorBrush x:Key="SelectedTabTextBrush" Color="#FF000000" />
    <!--  Black  -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FF0078D7" />
    <!--  Windows accent blue  -->
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#FFE0E0E0" />
    <!--  Light gray hover  -->
    <SolidColorBrush x:Key="ResizeGripBrush" Color="#888888" />

    <!--  Diff preview reassurance/info banner  -->
    <SolidColorBrush x:Key="DiffPreview.Reassurance.Background" Color="#F4F7FA" />
    <SolidColorBrush x:Key="DiffPreview.Reassurance.Border" Color="#D6DEE6" />
    <SolidColorBrush x:Key="DiffPreview.Reassurance.Foreground" Color="#1E2A36" />
    <SolidColorBrush x:Key="DiffPreview.SupportingText.Foreground" Color="#4A5968" />
    <SolidColorBrush x:Key="DiffPreview.EmptyState.Foreground" Color="#5C6977" />

    <!--  TreeViewControl-specific brushes  -->
    <SolidColorBrush x:Key="TreeNode.Background" Color="Transparent" />
    <SolidColorBrush x:Key="TreeNode.Foreground" Color="#000000" />
    <SolidColorBrush x:Key="TreeNode.Selected.Background" Color="#CCE8FF" />
    <SolidColorBrush x:Key="TreeNode.Selected.Foreground" Color="#000000" />
    <SolidColorBrush x:Key="TreeNode.Hover.Background" Color="#E8F2FE" />
    <SolidColorBrush x:Key="TreeNode.Hover.Foreground" Color="#000000" />
    <SolidColorBrush x:Key="TreeNode.Focus.Border" Color="#0078D7" />
    <SolidColorBrush x:Key="TreeNode.Disabled.Foreground" Color="#A0A0A0" />
    <SolidColorBrush x:Key="TreeNode.Glyph.Foreground" Color="#646464" />
    <SolidColorBrush x:Key="TreeNode.Glyph.Hover" Color="#000000" />

    <!--  Checkbox brushes for light theme  -->
    <SolidColorBrush x:Key="Checkbox.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Checkbox.Border" Color="#717171" />
    <SolidColorBrush x:Key="Checkbox.Glyph" Color="#212121" />
    <SolidColorBrush x:Key="Checkbox.Hover.Background" Color="#F3F9FF" />
    <SolidColorBrush x:Key="Checkbox.Hover.Border" Color="#005499" />
    <SolidColorBrush x:Key="Checkbox.Checked.Background" Color="#0078D7" />
    <SolidColorBrush x:Key="Checkbox.Checked.Border" Color="#0078D7" />
    <SolidColorBrush x:Key="Checkbox.Disabled.Background" Color="#F0F0F0" />
    <SolidColorBrush x:Key="Checkbox.Disabled.Border" Color="#C6C6C6" />
    <SolidColorBrush x:Key="Checkbox.Disabled.Glyph" Color="#A0A0A0" />
    <!--  Menu popup brushes for toolbar-backed menu bar  -->
    <SolidColorBrush x:Key="MenuPopupBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MenuPopupBorder" Color="#CCCCCC" />
    <SolidColorBrush x:Key="MenuPopupForeground" Color="#000000" />
    <SolidColorBrush x:Key="MenuPopupHoverBackground" Color="#E0E0E0" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#D0D0D0" />
    <SolidColorBrush x:Key="HighlightBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="PressedBrush" Color="#D0D0D0" />
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#999999" />
    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#000000" />
    <!--
        Scoped menu-item style for ContextMenu surfaces only.
        This restores compact context-menu spacing without reintroducing
        application-wide Menu/MenuItem chrome behavior.
    -->
    <Style x:Key="ContextMenuItemStyle" BasedOn="{x:Null}" TargetType="MenuItem">
        <Setter Property="Foreground" Value="#000000" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border
                            x:Name="OuterBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Path
                                    x:Name="CheckMark"
                                    Grid.Column="0"
                                    Width="9"
                                    Height="9"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Data="M 1,5 L 4,8 L 9,2"
                                    Stroke="#333333"
                                    StrokeEndLineCap="Round"
                                    StrokeLineJoin="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="1.5"
                                    Visibility="Collapsed" />

                                <ContentPresenter
                                    Grid.Column="1"
                                    ContentSource="Header"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    RecognizesAccessKey="True" />

                                <TextBlock
                                    Grid.Column="2"
                                    Margin="6,0,4,0"
                                    VerticalAlignment="Center"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding InputGestureText}" />
                            </Grid>
                        </Border>

                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            Focusable="False"
                            IsOpen="{TemplateBinding IsSubmenuOpen}"
                            Placement="Right"
                            PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                            <Border
                                Background="#FFFFFF"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="Gray" />
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E0E0E0" />
                        </Trigger>

                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter Property="Background" Value="#E0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{x:Null}" TargetType="ContextMenu">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Foreground" Value="#000000" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Style.Resources>
            <Style TargetType="MenuItem" BasedOn="{StaticResource ContextMenuItemStyle}" />
        </Style.Resources>
    </Style>

    <!--
        Explicit keyed alias of the implicit ContextMenu style.
        Assign via Style="{DynamicResource ToolbarContextMenuStyle}" on any
        ContextMenu that must be reliably themed regardless of its position
        in the logical tree.
    -->
    <Style x:Key="ToolbarContextMenuStyle" TargetType="ContextMenu" BasedOn="{StaticResource {x:Type ContextMenu}}" />

    <!--  ResizeGrip Style  -->
    <Style TargetType="ResizeGrip">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Cursor" Value="SizeNWSE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ResizeGrip">
                    <Border Background="Transparent">
                        <Canvas Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <!--  1 dot  -->
                            <Rectangle Canvas.Left="8" Canvas.Top="0" Width="2" Height="2" Fill="{DynamicResource ResizeGripBrush}" />
                            <!--  2 dots  -->
                            <Rectangle Canvas.Left="4" Canvas.Top="4" Width="2" Height="2" Fill="{DynamicResource ResizeGripBrush}" />
                            <Rectangle Canvas.Left="8" Canvas.Top="4" Width="2" Height="2" Fill="{DynamicResource ResizeGripBrush}" />
                            <!--  3 dots  -->
                            <Rectangle Canvas.Left="0" Canvas.Top="8" Width="2" Height="2" Fill="{DynamicResource ResizeGripBrush}" />
                            <Rectangle Canvas.Left="4" Canvas.Top="8" Width="2" Height="2" Fill="{DynamicResource ResizeGripBrush}" />
                            <Rectangle Canvas.Left="8" Canvas.Top="8" Width="2" Height="2" Fill="{DynamicResource ResizeGripBrush}" />
                        </Canvas>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    </ResourceDictionary>
